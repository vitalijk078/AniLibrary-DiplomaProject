{
  "name": "animehub-frontend-ru",
  "version": "1.1.0",
  "private": true,
  "description": "Anime catalog web application.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
